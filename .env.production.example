# App
NEXT_PUBLIC_APP_URL=https://your-production-domain.com
NODE_ENV=production

# Stripe (LIVE)
STRIPE_SECRET_KEY=sk_live_replace_with_live_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_live_webhook_secret
STRIPE_PRICE_ID_MARKETING_DIGITAL_APLICAT=price_replace_with_live_price_id
NEXT_PUBLIC_STRIPE_CHECKOUT_TEST_MODE=false

# Course access delivery
COURSE_ACCESS_TOKEN_SECRET=replace_with_long_random_production_secret
COURSE_ACCESS_LINK_TTL_HOURS=72
COURSE_MATERIALS_URL_MARKETING_DIGITAL_APLICAT=https://your-production-domain.com/materiale-marketing

# reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=replace_with_production_recaptcha_site_key
RECAPTCHA_SECRET_KEY=replace_with_production_recaptcha_secret_key
RECAPTCHA_THRESHOLD=0.7

# SMTP / Email
SMTP_HOST=mail.your-domain.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@your-domain.com
SMTP_PASSWORD=replace_with_production_smtp_password
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=NOMES
CONTACT_RECIPIENT_EMAIL=contact@your-domain.com
EMAIL_REPLY_TO=contact@your-domain.com
